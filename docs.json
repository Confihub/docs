{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Confi.cash",
  "description": "A non-custodial privacy protocol for shielded transfers, shared batch swaps through Stellar AMMs, and a simulated anchor payout flow on Stellar testnet.",
  "public": true,
  "colors": {
    "primary": "#0B7D5C",
    "light": "#22AD83",
    "dark": "#0B7D5C"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navigation": {
    "groups": [
      {
        "group": "Product overview",
        "pages": [
          "index",
          "concepts/how-it-works",
          "concepts/privacy-model"
        ]
      },
      {
        "group": "User guides",
        "pages": [
          "quickstart",
          "guides/add-money",
          "guides/send",
          "guides/swap",
          "guides/re-shield",
          "guides/cash-out",
          "guides/offramp"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/wallets",
          "reference/testnet",
          "faq"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Open Confi.cash",
          "href": "https://confi.cash",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "Network status",
          "href": "https://confi.cash/api/health",
          "icon": "activity"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Report a docs issue",
        "href": "https://github.com/Confihub/docs/issues"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch testnet app",
      "href": "https://confi.cash"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  },
  "seo": {
    "indexing": "navigable"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Confihub/docs"
    }
  }
}
